        let mut validator = ::caesura_options::OptionsValidator::new();
        let limit = self.limit;
        let resolved = NoCommandOptions {
            limit: limit.unwrap_or_else(|| 100),
        };
        if validate {
            resolved.validate(&mut validator);
        }
        let issues = validator.into_issues();
        if issues.is_empty() {
            ::std::result::Result::Ok(resolved)
        } else {
            ::std::result::Result::Err(issues)
        }
    }
}
impl ::caesura_options::OptionsPartialContract for NoCommandOptionsPartial {
    type Resolved = NoCommandOptions;
    fn merge(&mut self, other: Self) {
        if self.limit.is_none() {
