    fn resolve_internal(
        self,
        validate: bool,
    ) -> ::std::result::Result<
        UploadOptions,
        ::std::vec::Vec<::caesura_options::OptionRule>,
    > {
        let mut errors = ::std::vec::Vec::new();
        let copy_transcode_to_content_dir = self.copy_transcode_to_content_dir;
        let copy_transcode_to = self.copy_transcode_to;
        let copy_torrent_to = self.copy_torrent_to;
        let torrent_client = self.torrent_client;
        let torrent_client_url = self.torrent_client_url;
        let torrent_client_username = self.torrent_client_username;
        let torrent_client_password = self.torrent_client_password;
        let torrent_client_savepath = self.torrent_client_savepath;
        let torrent_client_category = self.torrent_client_category;
        let torrent_client_tags = self.torrent_client_tags;
        let torrent_client_paused = self.torrent_client_paused;
        let torrent_client_skip_checking = self.torrent_client_skip_checking;
        let dry_run = self.dry_run;
        let resolved = UploadOptions {
            copy_transcode_to_content_dir: copy_transcode_to_content_dir
                .unwrap_or_default(),
            copy_transcode_to,
            copy_torrent_to,
            torrent_client,
            torrent_client_url,
            torrent_client_username,
            torrent_client_password,
            torrent_client_savepath,
            torrent_client_category,
            torrent_client_tags,
            torrent_client_paused: torrent_client_paused.unwrap_or_default(),
            torrent_client_skip_checking: torrent_client_skip_checking
                .unwrap_or_default(),
            dry_run: dry_run.unwrap_or_default(),
        };
        if validate {
            resolved.validate(&mut errors);
        }
        if errors.is_empty() {
            ::std::result::Result::Ok(resolved)
        } else {
            ::std::result::Result::Err(errors)
        }
