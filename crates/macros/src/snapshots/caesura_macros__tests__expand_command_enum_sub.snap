/// Clap sub-command arguments for [`QueueCommand`].
#[derive(::clap::Subcommand, ::std::clone::Clone, ::std::fmt::Debug)]
pub enum QueueCommandArgs {
    /// Add to queue
    Add {
        /// Flattened `ConfigOptions` arguments.
        #[command(flatten)]
        config_options: ConfigOptionsPartial,
        /// Flattened `QueueAddArgs` arguments.
        #[command(flatten)]
        queue_add_args: QueueAddArgsPartial,
    },
    /// Remove from queue
    #[command(name = "rm")]
    Remove {
        /// Flattened `QueueRemoveArgs` arguments.
        #[command(flatten)]
        queue_remove_args: QueueRemoveArgsPartial,
        /// Flattened `ConfigOptions` arguments.
        #[command(flatten)]
        config_options: ConfigOptionsPartial,
    },
}
impl ::caesura_options::CommandEnumContract for QueueCommand {
    /// All sub-command variants.
    fn all() -> &'static [QueueCommand] {
        &[QueueCommand::Add, QueueCommand::Remove]
    }
    /// Display name for documentation (includes parent command name).
    fn doc_name(&self) -> &'static str {
        match self {
            QueueCommand::Add => "queue add",
            QueueCommand::Remove => "queue rm",
        }
    }
    /// Option type names used by this sub-command.
    fn options_names(&self) -> &'static [&'static str] {
        match self {
            QueueCommand::Add => &["ConfigOptions", "QueueAddArgs"],
            QueueCommand::Remove => &["QueueRemoveArgs", "ConfigOptions"],
        }
    }
    /// Resolve a sub-command variant from [`::clap::ArgMatches`].
    fn resolve(
        matches: &::clap::ArgMatches,
    ) -> ::std::option::Option<(QueueCommand, ::clap::ArgMatches)> {
        let (name, sub_matches) = matches.subcommand()?;
        match name {
            "add" => {
                ::std::option::Option::Some((QueueCommand::Add, sub_matches.clone()))
            }
            "rm" => {
                ::std::option::Option::Some((QueueCommand::Remove, sub_matches.clone()))
            }
            _ => ::std::option::Option::None,
        }
    }
}
impl ::std::fmt::Display for QueueCommand {
    fn fmt(&self, f: &mut ::std::fmt::Formatter<'_>) -> ::std::fmt::Result {
        match self {
            QueueCommand::Add => f.write_str("add"),
            QueueCommand::Remove => f.write_str("rm"),
        }
    }
}
