        self,
        validate: bool,
    ) -> ::std::result::Result<
        NameOptions,
        ::std::vec::Vec<crate::options::OptionRule>,
    > {
        let mut errors = ::std::vec::Vec::new();
        let name = self.name;
        let name_template = self.name_template;
        let experimental_name_template = self.experimental_name_template;
        let resolved = NameOptions {
            name,
            name_template,
            experimental_name_template: experimental_name_template.unwrap_or_default(),
        };
        if validate {
            resolved.validate(&mut errors);
        }
        if errors.is_empty() {
            ::std::result::Result::Ok(resolved)
        } else {
            ::std::result::Result::Err(errors)
        }
    }
}
